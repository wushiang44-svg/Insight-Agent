# DeepSeek LLM (https://platform.deepseek.com) - one API key, model is picked per request.
# Check DeepSeek's docs/dashboard for the current valid model names before relying on the defaults below.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Used for search planning, item analysis, and sufficiency checks (many small/cheap calls).
FAST_MODEL=deepseek-v4-flash
# Used only for the final merchant report, where quality matters most.
PRO_MODEL=deepseek-v4-pro

# Reddit app credentials. Requires approval first under the "Responsible Builder" policy:
# https://support.reddithelp.com/hc/en-us/requests/new?ticket_form_id=14868593862164
# Then create/access the app at https://www.reddit.com/prefs/apps -> create app -> type "script"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=reddit-insight-agent/0.1 by your-reddit-username
